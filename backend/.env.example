# ============================================================
#  Trackr Backend — Environment Variables EXAMPLE
#  1. Copy this file:  copy .env.example .env
#  2. Fill in your values below
# ============================================================

NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB — local or Atlas
MONGO_URI=mongodb://localhost:27017/trackr

# Redis — optional, app runs fine without it
REDIS_URL=redis://localhost:6379

# JWT — change these strings in production
JWT_ACCESS_SECRET=your_long_random_access_secret_here
JWT_REFRESH_SECRET=your_long_random_refresh_secret_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

BCRYPT_ROUNDS=12
