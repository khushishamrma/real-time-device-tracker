{
  "name": "trackr",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:backend": "npm install --prefix backend",
    "install:frontend": "npm install --prefix frontend",
    "install:simulator": "npm install --prefix simulator",
    "install:all": "npm run install:backend && npm run install:frontend && npm run install:simulator",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "start:backend": "npm start --prefix backend",
    "simulate": "node simulator/simulator.js"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}